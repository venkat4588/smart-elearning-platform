{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "importHelpers": true,
    "allowJs": false,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "typeRoots": ["node_modules/@types"],
    "types": [],
    "lib": ["ES2020", "DOM"]
  }
}
